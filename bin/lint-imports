#!/usr/bin/env bash

# Check that bottom-of-file Zig imports are alphabetized within each source file.

set -euo pipefail

# Note: avoid `mapfile` because the Bash that ships with macOS is old
status=0
while IFS= read -r path; do
  imports=$(grep '^const .* = @import(' "$path" || true)
  [[ -z "$imports" ]] && continue

  want=$(printf '%s\n' "$imports" | sort -f)
  if [[ "$imports" != "$want" ]]; then
    printf 'lint-imports: unsorted imports in %s\n' "$path"
    status=1
  fi
done < <(find src -name '*.zig' -type f | sort -f)

exit "$status"
