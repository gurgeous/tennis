#!/usr/bin/env ruby

# Updates the local Homebrew tap formula.

require "fileutils"
require "rbconfig"
require_relative "run_kit"

class HomebrewUpdate
  include RunKit

  OWNER = "gurgeous"
  PROJECT = "tennis"
  TAP_REPO = "homebrew-tap"
  GITHUB_REPO = "#{OWNER}/#{PROJECT}"

  SRC = Pathname("bin/tap.rb")
  DST = Pathname("../#{TAP_REPO}/#{PROJECT}.rb")
  TMP = Pathname("tmp/homebrew-update")
  PLATFORMS = %w[darwin_amd64 darwin_arm64 linux_amd64]
  EXT = {
    "darwin_amd64" => "tar.gz",
    "darwin_arm64" => "tar.gz",
    "linux_amd64" => "tar.gz",
    "windows_amd64" => "zip",
  }

  # main entry point
  def main
    # sanity check
    validate_paths!
    validate_formula!(file_read(DST))
    validate_release!(version)

    # update
    checksums = download_archives(version)
    render_formula(version, checksums)

    # hints
    warning("tap updated but not committed")
    puts "Next steps:"
    puts "  cd ../#{TAP_REPO}"
    puts "  git diff"
    puts "  git add #{PROJECT}.rb && git commit -m 'release v#{version}' && git push"
  end

  #
  # validation
  #

  def validate_paths!
    fatal("missing formula template: #{SRC}") if !SRC.exist?
    fatal("missing formula: #{DST}") if !DST.exist?
    fatal("missing gh") if !installed?("gh")
  end

  def validate_formula!(formula)
    # validate platforms
    exp = PLATFORMS.map { "#{_1}.tar.gz" }.sort
    project = Regexp.escape(PROJECT)
    actual = formula.scan(/#{project}_.+?_((?:darwin|linux)_[a-z0-9]+\.tar\.gz)/).flatten.sort
    fatal("formula platforms: expected #{exp}, got #{actual}") if actual != exp

    # look for versions
    versions = formula.scan(/^\s*version "([^"]+)"/).flatten
    versions.concat(formula.scan(%r{/releases/download/v([^/]+)/}).flatten)
    versions.concat(formula.scan(%r{#{project}_([^"/]+?)_(?:darwin|linux)_[a-z0-9]+\.tar\.gz}).flatten)
    fatal("formula has no version") if versions.empty?
    fatal("formula has mixed versions: #{versions}") if !versions.uniq.one?
  end

  # Require GitHub artifacts to match the complete release matrix exactly.
  def validate_release!(version)
    release = JSON.parse(shell!("gh", "release", "view", "v#{version}", "--repo", GITHUB_REPO, "--json", "assets"))
    actual = release.fetch("assets").map { _1.fetch("name") }.sort
    exp = EXT.keys.map { asset(version, _1) }.sort
    fatal("release assets: exp #{exp}, got #{actual}") if actual != exp
  end

  # Ensure each release archive contains the executable.
  def validate_archive!(archive)
    files = shell!("tar", "tzf", archive).lines.map(&:strip)
    fatal("archive missing #{PROJECT}: #{archive.basename}") if files.none? { _1.end_with?("/#{PROJECT}") }
  end


  #
  # Fetch/checksum archives
  #

  def download_archives(version)
    FileUtils.rm_rf(TMP)
    TMP.mkpath

    PLATFORMS.to_h do |platform|
      asset = asset(version, platform)
      banner("fetch #{asset}...")

      archive = TMP.join(asset)
      shell!("gh", "release", "download", "v#{version}", "--repo", GITHUB_REPO, "--pattern", asset, "--dir", TMP, "--clobber")
      validate_archive!(archive)
      [platform, Digest::SHA256.file(archive).hexdigest]
    end
  end

  #
  # Render and validate the whole formula before atomically replacing the tap copy.
  #

  def render_formula(version, checksums)
    vars = { repo: GITHUB_REPO, version: }
    checksums.each { |platform, checksum| vars["#{platform}_sha256".to_sym] = checksum }
    formula = render(file_read(SRC), vars)
    validate_formula!(formula)

    exp = PLATFORMS.map { url(version, _1) }.sort
    actual = formula.scan(/^\s*url "([^"]+)"/).flatten.sort
    fatal("generated formula has unexpected URLs") if actual != exp

    tmp = TMP.join("tap.rb")
    file_write(tmp, formula)
    syntax, status = shell(RbConfig.ruby, "-c", tmp)
    fatal("generated formula is invalid: #{syntax}") if status != 0

    banner "writing #{DST}..."
    file_write(DST, formula)
  end

  # Expand our small Mustache subset while detecting template/configuration drift.
  def render(template, vars)
    keys = template.scan(/\{\{([a-z0-9_]+)\}\}/).flatten.uniq
    provided = vars.keys.map(&:to_s)
    fatal("unknown template variables: #{keys - provided}") if !(keys - provided).empty?
    fatal("unused template variables: #{provided - keys}") if !(provided - keys).empty?

    template.gsub(/\{\{(\w+)\}\}/) { vars.fetch(Regexp.last_match(1).to_sym).to_s }.tap do
      fatal("unresolved template var") if _1.match?(/\{\{.*?\}\}/)
    end
  end

  # one-liners
  def version = @version ||= shell!("cargo", "pkgid", "-p", PROJECT).split(/[@#]/).last
  def asset(version, platform) = "#{PROJECT}_#{version}_#{platform}.#{EXT.fetch(platform)}"
  def url(version, platform) = "https://github.com/#{GITHUB_REPO}/releases/download/v#{version}/#{asset(version, platform)}"
end

Dir.chdir(Pathname(__dir__).parent.expand_path)
HomebrewUpdate.new.main
