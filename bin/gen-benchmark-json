#!/usr/bin/env bash

set -euo pipefail

awk 'BEGIN {
  n = 25000
  print "["
  for (r = 1; r <= n; r++) {
    printf "  {\"int1\":%d,\"float1\":%.6f,\"str1\":\"s%06d\",\"int2\":%d,\"float2\":%.6f,\"str2\":\"t%06d\",\"int3\":%d,\"float3\":%.6f,\"str3\":\"u%06d\",\"int4\":%d,\"float4\":%.6f,\"str4\":\"v%06d\",\"int5\":%d,\"float5\":%.6f,\"str5\":\"w%06d\",\"int6\":%d,\"float6\":%.6f,\"str6\":\"x%06d\",\"int7\":%d,\"float7\":%.6f}%s\n",
      r * 11,
      (r * 13) / 10.0,
      r,
      r * 17,
      (r * 19) / 100.0,
      r * 2,
      r * 23,
      (r * 29) / 1000.0,
      r * 3,
      r * 31,
      (r * 37) / 10.0,
      r * 4,
      r * 41,
      (r * 43) / 100.0,
      r * 5,
      r * 47,
      (r * 53) / 1000.0,
      r * 6,
      r * 59,
      (r * 61) / 10.0,
      (r < n ? "," : "")
  }
  print "]"
}'
